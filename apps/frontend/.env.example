# Frontend (SvelteKit)
# Base URL of the mock API service. In Docker compose this is the service name.
API_BASE_URL=http://localhost:4000
# WelshPAS assigning authority segment used in API paths.
ASSIGNING_AUTHORITY=AA149
# Required ONLY when running the production Node build (`pnpm start`) so
# adapter-node can validate same-origin form posts (CSRF). Not needed for the
# Vite dev server. Set to the externally reachable origin, e.g.:
# ORIGIN=http://localhost:5173
